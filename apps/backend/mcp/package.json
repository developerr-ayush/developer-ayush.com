{
  "name": "blog-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for managing blog posts via Claude AI agent",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "prisma": {
    "schema": "../prisma/schema.prisma"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "check-types": "tsc --noEmit",
    "db:generate": "prisma generate --schema ../prisma/schema.prisma"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "typescript": "5.8.2"
  }
}
